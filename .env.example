# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el .env a GitHub

# URL de conexión a Supabase (PostgreSQL)
DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# URL pública de tu Home Assistant (DDNS)
HOME_ASSISTANT_URL=https://antediluvian.tplinkdns.com

# Token de acceso de larga duración de Home Assistant
HOME_ASSISTANT_TOKEN=tu_token_aqui

# Intervalo de comprobación en segundos (por defecto 15)
CHECK_INTERVAL_SECONDS=15
