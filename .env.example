# ═══════════════════════════════════════════════════════════════
# Home Monitor - Variables de entorno
# Copia como .env y rellena los valores. NUNCA subas .env a Git.
# ═══════════════════════════════════════════════════════════════

# --- Entorno ---
APP_ENV=production
LOG_LEVEL=INFO
TZ=Europe/Madrid

# --- Seguridad (OBLIGATORIOS en producción) ---
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ACCESS_PASSWORD=
# Solo para desarrollo local sin auth (no usar en producción):
# ALLOW_INSECURE_NO_AUTH=true

# --- Base de datos PostgreSQL (OBLIGATORIOS) ---
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# --- Monitorización ---
CHECK_INTERVAL_SECONDS=15
MAX_CHECK_WORKERS=20

# --- Home Assistant (opcionales, necesarios para monitores HA) ---
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# --- Push Notifications VAPID (opcionales, necesarios para Web Push) ---
# Genera con: python -c "from pywebpush import webpush; from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_pem()); print(v.public_key)"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=

# --- Docker metrics (true por defecto, false si no montas el socket) ---
DOCKER_METRICS_ENABLED=true

# --- Status page (public, no auth required) ---
STATUS_PAGE_ENABLED=true

# --- NAS URL (para seed de dispositivo NAS) ---
NAS_URL=https://nas.local:5001
